# Database (provision via: vercel integration add neon --name jannah-parfume-db --plan free_v3)
# Vercel CLI writes full Neon vars to .env.local — use that for local dev.
DATABASE_URL=

# Auth (Better Auth)
BETTER_AUTH_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=jannah-parfume/products
